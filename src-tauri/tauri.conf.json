{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "ggbond",
    "version": "0.3.6",
    "identifier": "com.ggbond.desktop",
    "build": {
        "frontendDist": "../out",
        "devUrl": "http://localhost:3000/tauri-loading.html",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build:tauri-dist"
    },
    "app": {
        "windows": [
            {
                "title": "GGBond",
                "width": 1440,
                "height": 900,
                "resizable": true,
                "fullscreen": false,
                "decorations": true,
                "transparent": false,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true,
                "acceptFirstMouse": true,
                "trafficLightPosition": {
                    "x": 18,
                    "y": 24
                }
            }
        ],
        "security": {
            "csp": null
        },
        "macOSPrivateApi": true
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": {
            "resources/sidecar": "resources/sidecar",
            "resources/node-runtime": "resources/node-runtime",
            "../node_modules/better-sqlite3": "resources/sidecar/node_modules/better-sqlite3",
            "../node_modules/bindings": "resources/sidecar/node_modules/bindings",
            "../node_modules/file-uri-to-path": "resources/sidecar/node_modules/file-uri-to-path"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "signingIdentity": "-"
        }
    }
}
